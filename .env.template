# Copy this file to .env and fill in your actual values

# Gemini API key (required — used for embeddings and chat)
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Meta Ad Library access token (Phase 2, optional until Ad Library is wired up)
# Needs ads_read scope from a Meta developer app
META_AD_LIBRARY_TOKEN=

# Google Drive OAuth is handled via credentials.json + token.json in the repo root.
# Download OAuth client credentials (Desktop app) from Google Cloud Console
# and save as credentials.json. First run: python tools/fetch_gdocs.py --auth
